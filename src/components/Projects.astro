---
import NextJS from "./icons/NextJS.astro";
import Tailwind from "./icons/Tailwind.astro";
const TAGS = {
    NEXT: {
        name: 'Next.js',
        class: 'bg-black text-white',
        icon: NextJS,
    
    },

    TAILWIND:{
        name: 'TailwindCSS',
        class: 'bg-[#003159] text-white',
        icon: Tailwind,
    },
    }



const PROJECTS = [
    {
        title: "My Portfolio",
        description: "This is my personal portfolio, where you can know me more and also I showcase my projects and skills. It's built with Astro and TailwindCSS.",
        link: "https://juantobonv.netlify.app/",
        github: 'https://github.com/JuanTobonV/Portfolio',
        image: '/public/projects/svgl.webp',
        tags: [TAGS.NEXT, TAGS.TAILWIND],
    },
]
---

{
    PROJECTS.map(({ image, title, description, tags}) => (
        <article>
            <h3 class="text-2xl font-semibold text-yellow-200 mb-2">
                {title}
            </h3>

            <p class="text-lg mb-4 text-prettyy">
                {description}
            </p>
            <ul class="flex gap-x-2 flex-row">
                {tags.map((tag) => (
                    <li>
                        <span class={'flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2'}>
                       <tag.icon class="size-4" /> {tag.name}
                        </span>
                    </li>
                ))}
            </ul>
            <img class="rounded shadow-2xl shadow-white/10" src={image} alt={'Project Screenshot'}>
        </article>
    ))
}